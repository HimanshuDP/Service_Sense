# Firebase Service Account Key (download from Firebase Console → Project Settings → Service Accounts)
FIREBASE_SERVICE_ACCOUNT_KEY=./firebase-service-account.json

# Firebase Realtime Database URL (Firebase Console → Realtime Database → copy the URL)
# Format: https://your-project-id-default-rtdb.firebaseio.com
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# News API Key — https://newsapi.org
NEWS_API_KEY=your_news_api_key_here

# Grok / OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

GNEWS_API_KEY=your_gnews_api_key_here
